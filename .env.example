# GitHub Webhook Server 配置文件
# 复制为 .env 并修改实际值

# ============== 安全配置 ==============
# Webhook 验证密钥（必须与 GitHub 设置一致，建议使用强随机字符串）
WEBHOOK_SECRET=your_webhook_secret_here

# ============== 白名单配置 ==============
# 允许的组织/用户白名单（逗号分隔）
# 例如：ALLOWED_ORGS=your-company,your-org
ALLOWED_ORGS=your-company

# 允许的特定仓库白名单（逗号分隔，格式：owner/repo）
# 例如：ALLOWED_REPOS=your-company/docs,your-company/website
# 如果设置了 ALLOWED_ORGS，此项可选
ALLOWED_REPOS=

# ============== 网络配置 ==============
# 服务端口
PORT=5000

# 是否跳过 IP 检查（开发环境设为 true，生产环境建议 false）
SKIP_IP_CHECK=false

# ============== 部署配置 ==============
# 部署脚本路径
DEPLOY_SCRIPT=./deploy.sh

# 仓库目录（服务器上 git clone 的位置）
REPO_DIR=/var/www/docs-source

# 部署目录（nginx 服务的目录）
DEPLOY_DIR=/var/www/docs

# webhook server 所在目录
WEBHOOK_SERVER_DIR=/opt/webhook-server

# 日志文件
LOG_FILE=/var/log/webhook-deploy.log
